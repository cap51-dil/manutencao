[gcp_service_account]
type = "service_account"
project_id = "seu-projeto-gcp"
private_key_id = "cole-do-json"
client_email = "leitor-drive@seu-projeto.iam.gserviceaccount.com"
client_id = "cole-do-json"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/leitor-drive%40seu-projeto.iam.gserviceaccount.com"

# Formato recomendado: chave PEM em bloco multilinha (evita erro de PEM no Streamlit)
private_key = """
-----BEGIN PRIVATE KEY-----
COLE_AQUI_CADA_LINHA_DA_CHAVE_DO_JSON
UMA_LINHA_POR_VEZ_64_CARACTERES
...
-----END PRIVATE KEY-----
"""

[servicos]
"Manutenção" = "1EAp-v4dyjxdmaEP4c85hxVCQsRH6Og09"

[planilhas."Manutenção"]
"Câmaras de Vacina" = "STATUS CÂMARAS DE VACINA"
"Serviços Prioritários" = "SERVIÇOS PRIORITÁRIOS"

# Modo dev: arquivo .xlsx na raiz do projeto (opcional por planilha)
[locais."Manutenção"]
"Câmaras de Vacina" = "Cópia de STATUS CÂMARAS DE VACINA 2026 - AP 5.1.xlsx"

# Logo no cabeçalho: gradiente | azul | branco | preto
